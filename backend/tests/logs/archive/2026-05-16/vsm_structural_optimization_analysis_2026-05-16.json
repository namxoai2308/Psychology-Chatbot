  "optimization_plan": [
    {
      "priority": "P0",
      "area": "CBT stage progression",
      "action": "Replace turn-local CBT stage decisions with dialogue-state evidence counters: event captured, automatic thought captured, distortion named, insight captured, reframe captured. Advance by completed milestone rather than single-message keywords.",
      "expected_impact": "Reduce CBT stage mismatches and hard_fail caused by premature distortion labeling."
    },
    {
      "priority": "P0",
      "area": "CBT/Yalom peer policy",
      "action": "Split peer eligibility into factor + therapy-task + freshness. Nam contributes only once per emotional cluster; Linh contributes only on explicit hope/recovery or Stage 5 reframe. Add repetition budget.",
      "expected_impact": "Improve Yalom group and CBT peer match, reduce repeated peer output."
    },
    {
      "priority": "P1",
      "area": "BA long-session loop",
      "action": "Keep current probe fix, then add BA loop rules for session_core: after completion, user asking next step returns to stage2; new barrier returns to stage3; relapse with shame returns to stage1.",
      "expected_impact": "Improve BA all-split stage without hurting probe."
    },
    {
      "priority": "P1",
      "area": "MBI stress recovery",
      "action": "Add MBI relapse logic: acute panic -> stage1, recurring thought -> stage2, named body sensation -> stage3, closure action -> stage4; preserve stage4 only when no new cue appears.",
      "expected_impact": "Improve stress cases while keeping current strong MBI probe/core behavior."
    },
    {
      "priority": "P2",
      "area": "Deterministic scorer calibration",
      "action": "Add concept-level marker groups for valid Vietnamese phrasing only, e.g. micro-action as ngụm nước/đứng dậy 30 giây, not case-specific strings.",
      "expected_impact": "Avoid false negatives in deterministic technique score."
    }
  ],
